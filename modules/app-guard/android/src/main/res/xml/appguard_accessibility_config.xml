<?xml version="1.0" encoding="utf-8"?>
<!--
  Place this file at:
  modules/app-guard/android/src/main/res/xml/appguard_accessibility_config.xml

  This configures the AccessibilityService declaration in AndroidManifest.xml.
  accessibilityEventTypes: only TYPE_WINDOW_STATE_CHANGED — fires when a new app comes to foreground.
  packageNames: empty = monitor ALL packages (we filter in Kotlin).
  accessibilityFeedbackType: FEEDBACK_GENERIC — required, we don't actually give feedback.
  notificationTimeout: 100ms — minimum debounce between events.
  canRetrieveWindowContent: false — we don't need to read screen content, only package names.
-->
<accessibility-service
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:accessibilityEventTypes="typeWindowStateChanged"
  android:accessibilityFeedbackType="feedbackGeneric"
  android:notificationTimeout="100"
  android:canRetrieveWindowContent="false"
  android:description="@string/appguard_service_description" />
